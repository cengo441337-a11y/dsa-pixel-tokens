{
  "id": "dsa-pixel-tokens",
  "title": "DSA Pixel-Art Tokens",
  "description": "Komplettes Pixel-Art DSA 4.1 Erweiterungsmodul für FoundryVTT. Animierte Token-Sprites, automatische Zauber- und Kampfeffekte, Pixel-Art Heldenbogen, Zonenzauber mit Schaden, Proben-Automation und mehr.",
  "version": "0.3.0",
  "compatibility": {
    "minimum": "12",
    "verified": "12",
    "maximum": "12"
  },
  "authors": [
    {
      "name": "Deniz Ceylan",
      "url": "https://dc-infosec.de"
    }
  ],
  "relationships": {
    "systems": [
      {
        "id": "gdsa",
        "type": "system",
        "compatibility": {}
      }
    ],
    "requires": [
      {
        "id": "socketlib",
        "type": "module",
        "compatibility": {}
      },
      {
        "id": "lib-wrapper",
        "type": "module",
        "compatibility": {}
      }
    ],
    "recommends": [
      { "id": "actor-link-indicator",            "type": "module", "reason": "Zeigt ob Actor linked/unlinked — Pandaemonium-Cluster sind unlinked, da ist die Anzeige hilfreich" },
      { "id": "autocomplete-inline-properties",  "type": "module", "reason": "Bessere Journal-Bedienung" },
      { "id": "color-picker",                    "type": "module", "reason": "UI-Helper fuer Farbauswahl" },
      { "id": "combat-tracker-effect-tooltips",  "type": "module", "reason": "Bessere Uebersicht ueber Status-Effekte (unsere Wunden/Grapple-Flags werden lesbar)" },
      { "id": "compendium-folders",              "type": "module", "reason": "Verschachtelte Compendien fuer bessere Kreaturen-Organisation" },
      { "id": "dice-calculator",                 "type": "module", "reason": "Dice Tray — schnelle Wuerfe ohne Chat" },
      { "id": "fasar-stadtplan",                 "type": "module", "reason": "DSA-Stadtplaene (Fasar)" },
      { "id": "de-de-translation",               "type": "module", "reason": "Deutsche Foundry-Uebersetzung" },
      { "id": "grid-scaler",                     "type": "module", "reason": "Token-Groessen skalieren" },
      { "id": "journal-whiteboard",              "type": "module", "reason": "Zeichnen in Journals (fuer Taktik/Karten)" },
      { "id": "multi-token-status",              "type": "module", "reason": "Mehrere Status-Icons pro Token — passt zu unseren Wunden/Grapple-Flags" },
      { "id": "multilevel-tokens",               "type": "module", "reason": "Mehrstufige Karten (z.B. Taverne mit Kellerebene)" },
      { "id": "ownership-viewer",                "type": "module", "reason": "Zeigt wer was besitzt" },
      { "id": "pdf-pager",                       "type": "module", "reason": "PDFs (Regelbuecher, LCR) direkt in Foundry" },
      { "id": "popout",                          "type": "module", "reason": "Reisst unser Pandaemonium-Panel in eigenes Fenster — sehr empfohlen" },
      { "id": "simple-dice-roller",              "type": "module", "reason": "Schnelle Probe-Wuerfe" },
      { "id": "vtta-tokenizer",                  "type": "module", "reason": "Token-Avatar-Bau aus Portrait" }
    ]
  },
  "esmodules": [
    "scripts/module.mjs",
    "scripts/pixel-tokens.mjs"
  ],
  "styles": [
    "styles/pixel-tokens.css",
    "styles/sheet.css",
    "styles/dialogs.css"
  ],
  "languages": [
    {
      "lang": "de",
      "name": "Deutsch",
      "path": "lang/de.json"
    }
  ],
  "url": "https://github.com/cengo441337-a11y/dsa-pixel-tokens",
